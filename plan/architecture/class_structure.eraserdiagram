// DEPENDENCY FLOWS
// ============================================

// Core Dependencies
reservation_service.py > repository.py: Uses Protocol
reservation_service.py > qr_generator.py: Generates QR
reservation_service.py > time_calculator.py: Calculates time
reservation_service.py > reservation.py: Uses Models
reservation_service.py > validators.py: Validates input
reservation_service.py > exceptions.py: Raises errors

// Model Dependencies
reservation.py > Pydantic: Extends BaseModel
reservation.py > Python Standard: Uses datetime, UUID, Enum

// Storage Dependencies
in_memory_repository.py > repository.py: Implements Protocol
in_memory_repository.py > reservation.py: Stores Reservation
in_memory_repository.py > Python Standard: Uses threading.Lock

// QR Generator Dependencies
qr_generator.py > QRCode Library: Generates QR images
qr_generator.py > Python Standard: Uses base64, json, UUID

// Validator Dependencies
validators.py > exceptions.py: Raises validation errors
validators.py > Python Standard: Uses regex

// Config Dependencies
config.py > Pydantic: Extends BaseSettings

// ============================================
// DESIGN PATTERNS USED
// ============================================

Design Patterns [color: yellow] {
  
  Repository Pattern [icon: database] {
    Purpose: Abstract data persistence
    Implementation: ReservationRepository Protocol
    Benefits: Easy to swap storage backends
  }
  
  Dependency Injection [icon: arrow-right] {
    Purpose: Loose coupling
    Implementation: ReservationService constructor
    Benefits: Testable, flexible
  }
  
  Strategy Pattern [icon: settings] {
    Purpose: Interchangeable algorithms
    Implementation: TimeCalculator, QRGenerator
    Benefits: Different fee calculations
  }
  
  Factory Method [icon: box] {
    Purpose: Object creation
    Implementation: UUID generation, QR creation
    Benefits: Consistent object creation
  }
  
  Data Transfer Object [icon: file-text] {
    Purpose: Data encapsulation
    Implementation: Pydantic models
    Benefits: Validation, serialization
  }
}

// ============================================
// SOLID PRINCIPLES APPLIED
// ============================================

SOLID Principles [color: green] {
  
  Single Responsibility [icon: check] {
    Each class has one reason to change
    - QRGenerator: Only QR operations
    - TimeCalculator: Only time calculations
    - ReservationService: Only reservation logic
  }
  
  Open/Closed [icon: unlock] {
    Open for extension, closed for modification
    - Repository Protocol allows new implementations
    - Can add new validators without changing core
  }
  
  Liskov Substitution [icon: shuffle] {
    Subtypes must be substitutable
    - Any ReservationRepository implementation works
    - InMemoryRepository is substitutable
  }
  
  Interface Segregation [icon: layers] {
    Clients shouldn't depend on unused interfaces
    - Repository has minimal interface
    - Each utility function is focused
  }
  
  Dependency Inversion [icon: chevrons-down] {
    Depend on abstractions, not concretions
    - Service depends on Repository Protocol
    - Not on InMemoryReservationRepository
  }
}

